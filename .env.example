APP_NAME=NestyAI
APP_VERSION=0.1.0
APP_ENV=development

GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

REQUEST_TIMEOUT_SECONDS=30
ENABLE_INPUT_GUARD=true
ENABLE_OUTPUT_GUARD=true

# Optional if you want to enable NVIDIA OpenAI-compatible endpoint routing
NVIDIA_BASE_URL=

# Optional for Phase 3 tool foundations
WEATHER_PROVIDER_API_KEY=
EXCHANGE_RATE_API_KEY=

# Phase 4: auth, rate limit, usage tracking
NESTY_DB_PATH=data/nesty.db
NESTY_API_KEY_HASH_SECRET=
REQUIRE_API_KEY=false
PUBLIC_HEALTH=true
PUBLIC_MODELS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
SAFE_DEBUG_AUTH=false

# Phase 5.2: deployment hardening
CORS_ENABLED=false
CORS_ALLOW_ORIGINS=
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Nesty-API-Key
CORS_ALLOW_CREDENTIALS=false
TRUSTED_HOSTS=
MAX_REQUEST_BODY_BYTES=1048576
SECURITY_HEADERS_ENABLED=true
ENABLE_HSTS=false

# Phase 6: conversation session memory foundation
CONVERSATION_HISTORY_ENABLED=true
CONVERSATION_HISTORY_MAX_MESSAGES=20
CONVERSATION_HISTORY_MAX_CHARS=12000

# Phase 6.1: conversation summarization and history compression
CONVERSATION_SUMMARY_ENABLED=true
CONVERSATION_SUMMARY_TRIGGER_MESSAGES=30
CONVERSATION_SUMMARY_KEEP_RECENT_MESSAGES=12
CONVERSATION_SUMMARY_MAX_CHARS=4000
CONVERSATION_SUMMARY_MODEL=nesty-flash-1.0
